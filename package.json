{
  "name": "pi-knowledge",
  "version": "0.1.0",
  "description": "Vector knowledge base extension for Pi — index files, hybrid search, local embeddings",
  "type": "module",
  "main": "index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-extension",
    "knowledge-base",
    "vector-search",
    "semantic-search",
    "rag",
    "embeddings"
  ],
  "scripts": {
    "check": "biome check --write --error-on-warnings .",
    "test": "vitest --run test/unit/",
    "test:e2e": "vitest --run test/e2e/",
    "bench": "vitest bench test/bench/"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1",
    "better-sqlite3": "11.9.1",
    "ignore": "7.0.5",
    "tree-sitter": "0.21.1",
    "tree-sitter-typescript": "0.23.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.19",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nczz/pi-knowledge.git"
  }
}
