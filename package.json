{
	"name": "pi-knowledge",
	"version": "0.4.1",
	"description": "Local-first RAG knowledge base for Pi agents with hybrid code/doc search, reranking, diagnostics, and large-project indexing",
	"type": "module",
	"main": "index.ts",
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"files": [
		"index.ts",
		"src/",
		".pi/",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"keywords": [
		"pi",
		"pi-extension",
		"ai-agent",
		"coding-agent",
		"knowledge-base",
		"local-first",
		"retrieval-augmented-generation",
		"hybrid-search",
		"bm25",
		"vector-search",
		"semantic-search",
		"code-search",
		"developer-tools",
		"rag",
		"embeddings"
	],
	"scripts": {
		"check": "biome check --write --error-on-warnings .",
		"test": "vitest --run test/unit/",
		"test:e2e": "vitest --run test/e2e/",
		"bench": "vitest bench test/bench/"
	},
	"dependencies": {
		"@huggingface/transformers": "3.8.1",
		"better-sqlite3": "11.9.1",
		"ignore": "7.0.5",
		"mammoth": "1.12.0",
		"tree-sitter": "0.22.4",
		"tree-sitter-go": "0.23.4",
		"tree-sitter-java": "0.23.5",
		"tree-sitter-python": "0.23.6",
		"tree-sitter-rust": "0.23.2",
		"tree-sitter-typescript": "0.23.2",
		"unpdf": "1.6.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/better-sqlite3": "7.6.13",
		"@types/node": "22.19.19",
		"vitest": "3.2.4"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nczz/pi-knowledge.git"
	}
}
